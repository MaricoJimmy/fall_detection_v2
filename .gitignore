*.h5
*.keras
*.joblib
models/**/*.pth
models/**/*.pt
models/**/*.onnx
models/**/*.h5
models/**/*.keras
models/**/*.joblib

# Ignore logs and outputs
logs/**/*.log
test_outputs/
*.log

# Keep the .gitkeep files
!.gitkeep
!datasets/.gitkeep
!datasets/skeleton_windows/.gitkeep
!models/.gitkeep
!models/skeleton/.gitkeep
!logs/.gitkeep
